// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-w": "workspace::CloseActiveDock",
    },
  },
  {
    "context": "RulesLibrary",
    "unbind": {
      "ctrl-w": "workspace::CloseWindow",
    },
  },
  {
    "context": "Pane",
    "unbind": {
      "ctrl-w": [
        "pane::CloseActiveItem",
        {
          "close_pinned": false,
        },
      ],
    },
  },
  {
    "context": "SettingsWindow",
    "unbind": {
      "ctrl-w": "workspace::CloseWindow",
    },
  },
  {
    "context": "SkillCreator",
    "unbind": {
      "ctrl-w": "workspace::CloseWindow",
    },
  },
  {
    "context": "SkillCreator > Editor",
    "unbind": {
      "ctrl-w": "workspace::CloseWindow",
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-shift-p": "command_palette::Toggle",
    },
  },
  {
    "context": "VimControl || ProjectPanel",
      "bindings": {
      "space e": "project_panel::Toggle",
    },
  },
  {
    "context": "VimControl || GitPanel",
    "bindings": {
      "space g g": "git_panel::Toggle",
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-shift-g": "git_panel::ToggleFocus",
    },
  },
  {
    "bindings": {
      "ctrl-shift-d": "debug_panel::Toggle"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-shift-d": "debug_panel::ToggleFocus"
    }
  },
  {
    "context": "Workspace",
      "bindings": {
      "ctrl-?": "agent::Toggle"
    }
  }
]
