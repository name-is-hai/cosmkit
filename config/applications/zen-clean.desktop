[Desktop Entry]
Name=Zen Browser Clean
Comment=Launch Zen Browser with clean environment
Exec=env -u LD_LIBRARY_PATH -u LIBRARY_PATH -u ZED_FLATPAK_LIB_PATH -u GI_TYPELIB_PATH -u GIO_EXTRA_MODULES -u GSETTINGS_SCHEMA_DIR -u FLATPAK_XDG_CACHE_HOME -u FLATPAK_XDG_CONFIG_HOME -u FLATPAK_XDG_DATA_HOME -u FLATPAK_XDG_STATE_HOME flatpak run app.zen_browser.zen %U
Terminal=false
Type=Application
Categories=Network;WebBrowser;
MimeType=text/html;application/xhtml+xml;x-scheme-handler/http;x-scheme-handler/https;
StartupNotify=true
NoDisplay=true
