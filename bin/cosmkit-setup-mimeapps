#!/usr/bin/env bash
set -euo pipefail

COSMKIT_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "$COSMKIT_HOME/scripts/lib/common.sh"
source "$COSMKIT_HOME/scripts/lib/symlink.sh"

link_path "$COSMKIT_HOME/config/mimeapps/mimeapps.list" "$HOME/.config/mimeapps.list"
link_path "$COSMKIT_HOME/config/mimeapps/cosmic-mimeapps.list" "$HOME/.config/cosmic-mimeapps.list"
