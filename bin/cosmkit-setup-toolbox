#!/usr/bin/env bash
set -euo pipefail

COSMKIT_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "$COSMKIT_HOME/scripts/lib/common.sh"
source "$COSMKIT_HOME/scripts/steps/toolbox.sh"

case "${1:-dev}" in
  dev)
    setup_dev_toolbox dev
    ;;
  *)
    setup_dev_toolbox "$1"
    ;;
esac
