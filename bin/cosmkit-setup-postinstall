#!/usr/bin/env bash
set -euo pipefail

COSMKIT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "$COSMKIT_DIR/scripts/lib/common.sh"

log_info "Running post-reboot setup..."

cosmkit-setup-shell
cosmkit-setup-zsh

log_ok "Post-reboot setup finished."
log_info "Optional: run toolbox setup with: cosmkit-toolbox-setup dev"
