#!/usr/bin/env bash
set -euo pipefail

COSMKIT_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "$COSMKIT_HOME/scripts/lib/common.sh"

log_info "Running post-reboot setup..."

cosmkit-setup-shell
cosmkit-setup-zsh
cosmkit-setup-devpod
cosmkit-setup-layer nvidia

log_ok "Post-reboot setup finished."
log_info "Optional: run toolbox setup with: cosmkit-toolbox-setup dev"
