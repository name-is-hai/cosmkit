#!/usr/bin/env bash
set -euo pipefail

COSMKIT_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "$COSMKIT_HOME/scripts/lib/common.sh"
source "$COSMKIT_HOME/scripts/lib/symlink.sh"

link_path "$COSMKIT_HOME/config/mise" "$HOME/.config/mise"

if command -v mise >/dev/null 2>&1; then
  mise install
  log_ok "Installed all packages needed"
fi
