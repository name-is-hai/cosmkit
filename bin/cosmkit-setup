#!/usr/bin/env bash
set -euo pipefail

COSMKIT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "$COSMKIT_DIR/scripts/lib/common.sh"

log_info "Starting full cosmkit setup..."

cosmkit-setup-environment
cosmkit-setup-repos
cosmkit-setup-layer full
cosmkit-setup-flatpak
cosmkit-setup-git
cosmkit-setup-ghostty 
cosmkit-setup-fonts
cosmkit-setup-cosmic

log_ok "cosmkit setup finished."
log_warn "Reboot if rpm-ostree changed your deployment."
